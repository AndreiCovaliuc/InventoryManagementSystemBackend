# Database
DB_URL=jdbc:postgresql://localhost:5432/inventory_management
DB_USERNAME=postgres
DB_PASSWORD=your_database_password

# Server
SERVER_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT (use a strong random key, minimum 32 characters)
JWT_SECRET=change_me_to_a_strong_random_secret_key_at_least_32_chars
JWT_EXPIRATION_MS=604800000

# AI Provider (Groq — get a free key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key
# AI_BASE_URL=https://api.groq.com/openai  # uncomment to override default
# AI_MODEL=llama-3.3-70b-versatile         # uncomment to use a different model

# Chat Encryption (use a strong random key, exactly 32 bytes)
ENCRYPTION_KEY=change_me_to_a_strong_random_32byte_key

# Optional: verbose logging for local development (omit in production)
# SHOW_SQL=true
# LOG_LEVEL_APP=DEBUG
# LOG_LEVEL_SQL=DEBUG
# LOG_LEVEL_SQL_PARAMS=TRACE
# LOG_LEVEL_SECURITY=DEBUG
